package BOJ2439Prac; // このクラスが属するパッケージ
import java.util.Scanner; // ユーザー入力を受け取るために Scanner クラスをインポート

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in); // Scanner オブジェクトを生成してユーザーの入力を受け取る
        // BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        // String input = br.readLine();
        // br.close();
        // のように Scanner の代わりに BufferedReader を使う方法もある

        // System.out.print("출력할 줄 수를 입력하세요 : ");
        // → BOJ のように出力形式が厳格なプラットフォームでは不正解になる可能性があるため、入力案内メッセージは不要
        int n = sc.nextInt(); // ユーザーから出力する行数を整数として入力してもらう

        // Scanner オブジェクトを閉じる → リソースの無駄遣いを防ぐ
        sc.close();

        // 1からnまで繰り返して各行を出力する
        for (int i = 1; i <= n; i++) {
            // スペースを出力する
            // 右寄せにするために n-i の数だけスペースを出力
            for (int j = 1; j <= n - i; j++) {
                System.out.print(" ");
            }

            // アスタリスク（*）を出力：i 回出力する
            for (int k = 1; k <= i; k++) {
                System.out.print("*");
            }

            // 1行の出力が終わったら改行
            System.out.println();
        }
    }
}

